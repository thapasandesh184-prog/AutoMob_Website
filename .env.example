# Database
# Use mysql.hostinger.com (or your Hostinger MySQL hostname)
# connection_limit=10: more concurrent connections
# pool_timeout=0: keep connections alive (no timeout)
# connect_timeout=10: fail fast if DB is unreachable
DATABASE_URL="mysql://username:password@mysql.hostinger.com:3306/database_name?connection_limit=10&pool_timeout=0&connect_timeout=10"

# NextAuth
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="your-random-secret-min-32-chars"

# Admin Credentials
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-admin-password"

# One-time setup secret for /api/setup-admin endpoint
SETUP_SECRET="your-random-setup-secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
